x.means <- replicate(1000, mean(rnorm(50)))
library(package = "lattice")
histogram(~ x.means, nint = 15)
qqmath(~ x.means, grid = TRUE)
x.means <- replicate(1000, mean(rnorm(50)))
library(package = "lattice")
histogram(~ x.means, nint = 15)
qqmath(~ x.means, grid = TRUE)
m=c();v=c();
for(x in 1:100){
n=rnorm(100);m[x]=mean(n);v[x]=var(n);
}
t=10*m/(v^(1/2))
hdata=hist(t,breaks=30)
fm=max(hdata$counts)
se=data.frame(t)
ggplot(se)+geom_histogram(aes(t),color="black",fill=NA,bins=30) +
geom_line(aes(t,dt(t,df=99)),color="red") +
geom_line(aes(t,dt(t,df=99)*fm/max(dt(t,df=99))),color="blue") +
xlab("t-static values")+ylab("Frequency")
